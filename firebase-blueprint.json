{
  "entities": {
    "Room": {
      "title": "Room",
      "description": "Represents an online game room",
      "type": "object",
      "properties": {
        "roomId": { "type": "string", "description": "Short code room ID" },
        "players": { "type": "array", "description": "Public player summaries" },
        "currentRound": { "type": "integer" },
        "currentTrickIndex": { "type": "integer" },
        "currentLeaderId": { "type": "string" },
        "currentTrickCards": { "type": "array" },
        "activePlayerIndex": { "type": "integer" },
        "status": { "type": "string", "enum": ["lobby", "playing", "round_end", "game_over"] },
        "winnerId": { "type": "string", "format": "nullable" },
        "tricksHistory": { "type": "array" },
        "lastRoundResult": { "type": "object", "format": "nullable" },
        "dealerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["roomId", "players", "status", "createdAt", "updatedAt"]
    },
    "PrivateHand": {
      "title": "PrivateHand",
      "description": "Secure, private hand cards for a player",
      "type": "object",
      "properties": {
        "playerId": { "type": "string" },
        "cards": { "type": "array" }
      },
      "required": ["playerId", "cards"]
    }
  },
  "firestore": {
    "/rooms/{roomId}": {
      "schema": { "$ref": "#/entities/Room" },
      "description": "Stores the shared state of a game room"
    },
    "/rooms/{roomId}/privateHands/{playerId}": {
      "schema": { "$ref": "#/entities/PrivateHand" },
      "description": "Stores the private hand cards of a specific player to prevent information leaks"
    }
  }
}
